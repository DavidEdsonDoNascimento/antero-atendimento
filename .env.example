# Antero Atendimento — variáveis de ambiente
# Copie este arquivo para `.env.local` e preencha com os valores do seu projeto.
# `.env.local` é ignorado pelo git e NUNCA deve ser commitado.
#
# Onde encontrar: Supabase Dashboard > Project Settings > API

# URL do projeto Supabase (ex.: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Chave anônima (anon / publishable).
# Segura para o navegador — o acesso aos dados é protegido por RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# (Opcional) Service role key — SOMENTE servidor.
# Concede acesso total ao banco, ignorando o RLS. Usada apenas por scripts
# administrativos executados no servidor. NUNCA exponha no navegador e NUNCA
# faça commit do valor real. Não é necessária para rodar a aplicação.
SUPABASE_SERVICE_ROLE_KEY=
